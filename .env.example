# Copy to `.env` (repo root) for local dev — never commit real keys.

# TomTom Traffic API key (same key enables map tiles + corridor Flow API).
# Build embed (optional): baked into the UI bundle at build time.
VITE_TOMTOM_KEY=

# API server only (optional): used when the browser does not send a key.
# Set this on Dokploy/production so corridors work before users paste Settings.
TOMTOM_API_KEY=
