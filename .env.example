# Copy to `.env` (repo root) for local dev — never commit real keys.

# TripBuddy API server (`npm run dev` from `server/` or combined dev).
# GWB upper-deck camera: each user saves a YouTube link in Settings (stored in PostgreSQL); no env key.

# TomTom Traffic: paste API key in the app under Settings → Map: TomTom traffic overlay.
# (Not read from env — keys stay in the browser unless you add a different integration.)

# WhatsApp (WAHA) — separate Dokploy/docker service; TripBuddy proxies via /api/waha
# WAHA_BASE_URL=http://your-waha-service:3000
# WAHA_API_KEY=your-plain-waha-api-key
# Optional Vite-only direct URL (usually leave unset; use server proxy instead):
# VITE_WAHA_URL=
# VITE_WAHA_API_KEY=
