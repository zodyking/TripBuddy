{
  "name": "fedextool",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"npm run dev --prefix server\" \"vite\"",
    "dev:ui": "vite",
    "dev:server": "npm run dev --prefix server",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "leaflet": "^1.9.4",
    "vue": "^3.5.31",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1"
  },
  "overrides": {
    "vite-plugin-inspect": {
      "vite": "$vite"
    },
    "vite-dev-rpc": {
      "vite": "$vite"
    },
    "vite-hot-client": {
      "vite": "$vite"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
