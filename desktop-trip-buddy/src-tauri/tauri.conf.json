{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trip Buddy",
  "version": "0.1.0",
  "identifier": "com.fedextool.tripbuddy",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "https://fdxtools.fedex.com/grdlhldispatch/home",
